NEXT_PUBLIC_APP_NAME="FinanceOS Private"

# local keeps the first version running with mock auth and browser storage.
# supabase enables Supabase Auth and the Supabase finance repository.
NEXT_PUBLIC_AUTH_PROVIDER=local
NEXT_PUBLIC_DATA_SOURCE=local

# Required only when NEXT_PUBLIC_AUTH_PROVIDER=supabase or NEXT_PUBLIC_DATA_SOURCE=supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
